<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — OnlineShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="header">
        <div class="container header__inner">
            <a href="/" class="logo">🛒 OnlineShop</a>
            <nav class="nav">
                <a href="/" class="nav__link">Каталог</a>
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a href="/Cart" class="nav__link nav__cart">
                        🛒 Кошик
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Products" class="nav__link">⚙️ Адмін</a>
                    }
                    <span class="nav__user">👤 @User.Identity.Name</span>
                    <form method="post" asp-controller="Account" asp-action="Logout" class="nav__logout-form">
                        <button type="submit" class="btn btn--outline btn--sm">Вийти</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn--outline btn--sm">Увійти</a>
                    <a href="/Account/Register" class="btn btn--primary btn--sm">Реєстрація</a>
                }
            </nav>
            <button class="burger" onclick="document.querySelector('.nav').classList.toggle('nav--open')">☰</button>
        </div>
    </header>

    <main class="main">
        <div class="container">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert--success">✅ @TempData["Message"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert--error">❌ @TempData["Error"]</div>
            }
            @RenderBody()
        </div>
    </main>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
