@model CartViewModel
@{
    ViewData["Title"] = "Кошик";
}

<h1 class="page-title">🛒 Кошик</h1>

@if (Model.Items.Any())
{
    <table class="cart-table">
        <thead>
            <tr>
                <th>Товар</th>
                <th>Ціна</th>
                <th>Кількість</th>
                <th>Сума</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td data-label="Товар">
                        <div class="cart-table__product">
                            <img src="@item.Product?.ImagePath" alt="@item.Product?.Name" class="cart-table__img" />
                            <a href="/Product/Details/@item.ProductId" class="cart-table__name">@item.Product?.Name</a>
                        </div>
                    </td>
                    <td data-label="Ціна">@((item.Product?.Price ?? 0).ToString("N0")) ₴</td>
                    <td data-label="Кількість">
                        <div class="cart-qty">
                            <form method="post" asp-controller="Cart" asp-action="UpdateQuantity">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                <button type="submit" class="cart-qty__btn">−</button>
                            </form>
                            <span class="cart-qty__val">@item.Quantity</span>
                            <form method="post" asp-controller="Cart" asp-action="UpdateQuantity">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                <button type="submit" class="cart-qty__btn">+</button>
                            </form>
                        </div>
                    </td>
                    <td data-label="Сума"><strong>@(((item.Product?.Price ?? 0) * item.Quantity).ToString("N0")) ₴</strong></td>
                    <td>
                        <form method="post" asp-controller="Cart" asp-action="Remove">
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <button type="submit" class="btn btn--danger btn--sm">✕</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="cart-total">
        <div class="cart-total__sum">Загалом: <span>@Model.TotalPrice.ToString("N0") ₴</span></div>
        <div class="cart-total__actions">
            <form method="post" asp-controller="Cart" asp-action="Clear">
                <button type="submit" class="btn btn--outline">Очистити кошик</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="cart-empty">
        <div class="cart-empty__icon">🛒</div>
        <p>Кошик порожній</p>
        <a href="/" class="btn btn--primary">Перейти до каталогу</a>
    </div>
}
