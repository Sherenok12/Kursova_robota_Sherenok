@model ProductFormViewModel
@{
    ViewData["Title"] = "Додати товар";
}

<div class="admin-nav">
    <a href="/Admin/Products" class="btn btn--outline btn--sm">← Назад до товарів</a>
</div>

<div class="auth-wrapper" style="max-width: 600px;">
    <div class="auth-card">
        <h1>Додати товар</h1>

        <form method="post" asp-action="CreateProduct">
            <div class="form-group">
                <label asp-for="Name">Назва</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="form-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="ShortDescription">Короткий опис</label>
                <input asp-for="ShortDescription" />
            </div>
            <div class="form-group">
                <label asp-for="FullDescription">Повний опис</label>
                <textarea asp-for="FullDescription" rows="4"></textarea>
            </div>
            <div class="form-group">
                <label asp-for="Price">Ціна (₴)</label>
                <input asp-for="Price" type="number" step="0.01" />
                <span asp-validation-for="Price" class="form-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="ImagePath">URL зображення</label>
                <input asp-for="ImagePath" placeholder="https://..." />
            </div>
            <div class="form-group">
                <label asp-for="CategoryId">Категорія</label>
                <select asp-for="CategoryId" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Categories, "Id", "Name"))">
                    <option value="">— Оберіть —</option>
                </select>
                <span asp-validation-for="CategoryId" class="form-error"></span>
            </div>
            <button type="submit" class="btn btn--primary btn--block">Створити</button>
        </form>
    </div>
</div>
