@model LoginViewModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h1>Вхід</h1>

        <div asp-validation-summary="All" class="form-error mb-20"></div>

        <form method="post" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl">
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="form-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" type="password" placeholder="••••••" />
                <span asp-validation-for="Password" class="form-error"></span>
            </div>
            <button type="submit" class="btn btn--primary btn--block">Увійти</button>
        </form>

        <div class="auth-footer">
            Немає акаунту? <a href="/Account/Register">Зареєструватися</a>
        </div>
    </div>
</div>
